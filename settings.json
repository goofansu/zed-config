{
  "cli_default_open_behavior": "existing_window",
  "ui_font_size": 16,
  "ui_font_family": "Aporetic Serif",
  "buffer_font_size": 16,
  "buffer_font_family": "Aporetic Sans Mono",

  "profiles": {
    "large": {
      "settings": {
        "ui_font_size": 24,
        "buffer_font_size": 24,
      },
    },
  },

  "theme": {
    "mode": "system",
    "light": "Modus Operandi",
    "dark": "Modus Vivendi",
  },

  "terminal": {
    "font_family": "Aporetic Sans Mono",
    "shell": "system",
    "minimum_contrast": 0,
  },

  "auto_install_extensions": {
    "dockerfile": true,
    "elixir": true,
    "haml": true,
    "html": true,
    "make": true,
    "modus-themes": true,
    "nix": true,
    "ruby": true,
    "scss": true,
    "toml": true,
    "vue": true,
    "xml": true,
  },

  "edit_predictions": {
    "provider": "none",
  },

  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {},
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "enable_thinking": true,
      "effort": "high",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": true,
        "effort": "high",
      },
    ],
    "model_parameters": [],
  },

  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"],
    },
  },
}
