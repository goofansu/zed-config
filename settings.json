{
  "ui_font_size": 16,
  "ui_font_family": "Aporetic Serif",
  "buffer_font_size": 16,
  "buffer_font_family": "Aporetic Sans Mono",

  "theme": {
    "mode": "system",
    "light": "Modus Operandi",
    "dark": "Modus Vivendi",
  },

  "terminal": {
    "font_family": "Aporetic Sans Mono",
    "shell": "system",
    "minimum_contrast": 0,
  },

  "auto_install_extensions": {
    "dockerfile": true,
    "elixir": true,
    "haml": true,
    "html": true,
    "make": true,
    "modus-themes": true,
    "nix": true,
    "ruby": true,
    "scss": true,
    "toml": true,
    "vue": true,
    "xml": true,
  },

  "profiles": {
    "large": {
      "settings": {
        "ui_font_size": 24,
        "buffer_font_size": 24,
      },
    },
  },

  "disable_ai": true,
  "enable_language_server": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "cli_default_open_behavior": "existing_window",
}
