{
  "theme": "Modus Vivendi",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "ui_font_family": "Aporetic Serif",
  "buffer_font_family": "Aporetic Sans Mono",

  "profiles": {
    "large": {
      "settings": {
        "ui_font_size": 24,
        "buffer_font_size": 24,
      },
    },
  },

  "auto_install_extensions": {
    "dockerfile": true,
    "elixir": true,
    "haml": true,
    "html": true,
    "make": true,
    "modus-themes": true,
    "nix": true,
    "ruby": true,
    "scss": true,
    "toml": true,
    "vue": true,
    "xml": true,
  },

  "enable_language_server": false,
  "cli_default_open_behavior": "existing_window",
  "edit_predictions": {
    "provider": "none",
  },
}
