{
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "ui_font_family": "Aporetic Serif",
  "buffer_font_family": "Aporetic Sans Mono",

  "profiles": {
    "large": {
      "settings": {
        "ui_font_size": 24,
        "buffer_font_size": 24,
      },
    },
  },

  "theme": {
    "mode": "system",
    "light": "Modus Operandi",
    "dark": "Modus Vivendi",
  },

  "terminal": {
    "font_family": "Aporetic Sans Mono",
    "minimum_contrast": 0,
  },

  "auto_install_extensions": {
    "dockerfile": true,
    "elixir": true,
    "haml": true,
    "html": true,
    "make": true,
    "modus-themes": true,
    "nix": true,
    "ruby": true,
    "scss": true,
    "toml": true,
    "vue": true,
    "xml": true,
  },

  "enable_language_server": false,
  "cli_default_open_behavior": "existing_window",

  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {},
    },
    "default_profile": "write",
    "default_model": {
      "effort": "max",
      "provider": "deepseek",
      "model": "deepseek-v4-pro",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },

  "edit_predictions": {
    "provider": "none",
  },
}
